---
/**
 * Custom 404 Error Page
 * Bilingual not-found page that detects locale from the URL prefix.
 * Uses BaseLayout for consistent site branding.
 * Validates: Requirements 5.5, 10.4
 */
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getLocaleFromUrl } from "@/lib/i18n/utils";
import { i18nConfig } from "@/lib/i18n/config";
import type { Locale } from "@/lib/i18n/config";

const locale: Locale = getLocaleFromUrl(Astro.url);
const prefix = i18nConfig.urlPrefix[locale];

const content = {
  id: {
    title: "Halaman Tidak Ditemukan - infotour.id",
    heading: "404",
    subheading: "Halaman Tidak Ditemukan",
    message: "Maaf, halaman yang Anda cari tidak tersedia atau telah dipindahkan.",
    suggestion: "Coba jelajahi destinasi wisata kami atau kunjungi halaman utama.",
    homeLink: "Kembali ke Beranda",
    directoryLink: "Lihat Semua Destinasi",
    blogLink: "Baca Blog",
  },
  en: {
    title: "Page Not Found - infotour.id",
    heading: "404",
    subheading: "Page Not Found",
    message: "Sorry, the page you are looking for doesn't exist or has been moved.",
    suggestion: "Try exploring our tourism destinations or visit the homepage.",
    homeLink: "Back to Home",
    directoryLink: "View All Destinations",
    blogLink: "Read Blog",
  },
};

const t = content[locale];
---

<BaseLayout title={t.title} description={t.message}>
  <section class="flex flex-1 items-center justify-center px-4 py-16 md:py-24">
    <div class="text-center max-w-md mx-auto">
      <p class="text-6xl font-bold text-primary mb-4">{t.heading}</p>
      <h1 class="text-2xl md:text-3xl font-semibold text-foreground mb-4">
        {t.subheading}
      </h1>
      <p class="text-muted-foreground mb-2">
        {t.message}
      </p>
      <p class="text-muted-foreground mb-8">
        {t.suggestion}
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a
          href={`${prefix}/`}
          class="inline-flex items-center justify-center rounded-md bg-primary px-6 py-3 text-sm font-medium text-primary-foreground shadow hover:bg-primary/90 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring min-h-touch"
        >
          {t.homeLink}
        </a>
        <a
          href={`${prefix}/destinations`}
          class="inline-flex items-center justify-center rounded-md border border-input bg-background px-6 py-3 text-sm font-medium text-foreground shadow-sm hover:bg-accent hover:text-accent-foreground transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring min-h-touch"
        >
          {t.directoryLink}
        </a>
        <a
          href={`${prefix}/blog`}
          class="inline-flex items-center justify-center rounded-md border border-input bg-background px-6 py-3 text-sm font-medium text-foreground shadow-sm hover:bg-accent hover:text-accent-foreground transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring min-h-touch"
        >
          {t.blogLink}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
