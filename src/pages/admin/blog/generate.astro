---
/**
 * Blog AI Generation Page (SSR)
 * Provides UI to trigger AI blog article generation with target language selector.
 * Validates: Requirements 6.1, 6.3, 6.6
 */
export const prerender = false;

import AdminLayout from "@/layouts/AdminLayout.astro";
---

<AdminLayout title="Generate Artikel AI">
  <div class="max-w-2xl space-y-6">
    <!-- Header -->
    <div>
      <h2 class="text-2xl font-bold text-gray-900">Generate Artikel Blog</h2>
      <p class="mt-1 text-sm text-gray-600">
        Gunakan AI untuk membuat draf artikel blog berdasarkan topik dan kata kunci.
      </p>
    </div>

    <!-- Generation form -->
    <div class="bg-white rounded-lg border border-gray-200 p-6 shadow-sm">
      <form id="generate-form" class="space-y-5">
        <!-- Topic -->
        <div>
          <label for="topic" class="block text-sm font-medium text-gray-700 mb-1">
            Topik Artikel <span class="text-red-500">*</span>
          </label>
          <input
            type="text"
            id="topic"
            name="topic"
            required
            placeholder="Contoh: Wisata Alam di Bali Kintamani"
            class="w-full min-h-[44px] px-3 py-2.5 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-purple-500 focus:border-purple-500 outline-none transition-colors"
          />
          <p class="mt-1 text-xs text-gray-500">Topik utama yang akan dibahas dalam artikel.</p>
        </div>

        <!-- Keywords -->
        <div>
          <label for="keywords" class="block text-sm font-medium text-gray-700 mb-1">
            Kata Kunci
          </label>
          <input
            type="text"
            id="keywords"
            name="keywords"
            placeholder="Contoh: kintamani, danau batur, trekking, sunrise"
            class="w-full min-h-[44px] px-3 py-2.5 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-purple-500 focus:border-purple-500 outline-none transition-colors"
          />
          <p class="mt-1 text-xs text-gray-500">Pisahkan kata kunci dengan koma. Opsional.</p>
        </div>

        <!-- Target Language -->
        <div>
          <label for="targetLanguage" class="block text-sm font-medium text-gray-700 mb-1">
            Bahasa Target <span class="text-red-500">*</span>
          </label>
          <div class="flex gap-4">
            <label class="flex items-center gap-2 cursor-pointer">
              <input
                type="radio"
                name="targetLanguage"
                value="id"
                checked
                class="w-4 h-4 text-purple-600 border-gray-300 focus:ring-purple-500"
              />
              <span class="text-sm text-gray-700 flex items-center gap-1.5">
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">ID</span>
                Bahasa Indonesia
              </span>
            </label>
            <label class="flex items-center gap-2 cursor-pointer">
              <input
                type="radio"
                name="targetLanguage"
                value="en"
                class="w-4 h-4 text-purple-600 border-gray-300 focus:ring-purple-500"
              />
              <span class="text-sm text-gray-700 flex items-center gap-1.5">
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">EN</span>
                English
              </span>
            </label>
          </div>
        </div>

        <!-- Submit button -->
        <div class="pt-2">
          <button
            type="submit"
            id="generate-btn"
            class="inline-flex items-center px-5 py-2.5 text-sm font-medium text-white bg-purple-600 hover:bg-purple-700 rounded-lg transition-colors min-h-[44px] disabled:bg-purple-300 disabled:cursor-not-allowed"
          >
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
            Generate Artikel
          </button>
        </div>
      </form>
    </div>

    <!-- Loading state -->
    <div id="loading-state" class="hidden bg-white rounded-lg border border-gray-200 p-6 shadow-sm">
      <div class="flex items-center gap-3">
        <svg class="animate-spin w-5 h-5 text-purple-600" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
        </svg>
        <div>
          <p class="text-sm font-medium text-gray-900">Sedang membuat artikel...</p>
          <p class="text-xs text-gray-500 mt-0.5">AI sedang meneliti topik dan menulis konten. Proses ini membutuhkan waktu beberapa detik.</p>
        </div>
      </div>
    </div>

    <!-- Error state -->
    <div id="error-state" class="hidden bg-red-50 rounded-lg border border-red-200 p-6">
      <div class="flex items-start gap-3">
        <svg class="w-5 h-5 text-red-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <div class="flex-1">
          <p class="text-sm font-medium text-red-800">Gagal membuat artikel</p>
          <p id="error-message" class="text-sm text-red-700 mt-1"></p>
          <button
            type="button"
            id="retry-btn"
            class="mt-3 inline-flex items-center px-3 py-1.5 text-xs font-medium text-red-700 bg-red-100 hover:bg-red-200 rounded-md transition-colors min-h-[36px]"
          >
            <svg class="w-3.5 h-3.5 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
            </svg>
            Coba Lagi
          </button>
        </div>
      </div>
    </div>

    <!-- Success state -->
    <div id="success-state" class="hidden bg-green-50 rounded-lg border border-green-200 p-6">
      <div class="flex items-start gap-3">
        <svg class="w-5 h-5 text-green-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
        </svg>
        <div class="flex-1">
          <p class="text-sm font-medium text-green-800">Artikel berhasil dibuat!</p>
          <p class="text-sm text-green-700 mt-1">Draf artikel telah disimpan. Anda dapat mengedit sebelum mempublikasi.</p>
          <a
            id="edit-link"
            href="#"
            class="mt-3 inline-flex items-center px-3 py-1.5 text-xs font-medium text-green-700 bg-green-100 hover:bg-green-200 rounded-md transition-colors min-h-[36px]"
          >
            Edit Artikel →
          </a>
        </div>
      </div>
    </div>
  </div>

  <script>
    const form = document.getElementById("generate-form") as HTMLFormElement;
    const generateBtn = document.getElementById("generate-btn") as HTMLButtonElement;
    const loadingState = document.getElementById("loading-state") as HTMLDivElement;
    const errorState = document.getElementById("error-state") as HTMLDivElement;
    const errorMessage = document.getElementById("error-message") as HTMLParagraphElement;
    const successState = document.getElementById("success-state") as HTMLDivElement;
    const editLink = document.getElementById("edit-link") as HTMLAnchorElement;
    const retryBtn = document.getElementById("retry-btn") as HTMLButtonElement;

    function showLoading() {
      loadingState.classList.remove("hidden");
      errorState.classList.add("hidden");
      successState.classList.add("hidden");
      generateBtn.disabled = true;
      generateBtn.innerHTML = `
        <svg class="animate-spin w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
        </svg>
        Memproses...
      `;
    }

    function showError(message: string) {
      loadingState.classList.add("hidden");
      errorState.classList.remove("hidden");
      successState.classList.add("hidden");
      errorMessage.textContent = message;
      generateBtn.disabled = false;
      generateBtn.innerHTML = `
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
        </svg>
        Generate Artikel
      `;
    }

    function showSuccess(articleId: string) {
      loadingState.classList.add("hidden");
      errorState.classList.add("hidden");
      successState.classList.remove("hidden");
      editLink.href = `/admin/blog/${articleId}/edit`;
      generateBtn.disabled = false;
      generateBtn.innerHTML = `
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
        </svg>
        Generate Artikel
      `;
    }

    async function submitGeneration() {
      const topicInput = document.getElementById("topic") as HTMLInputElement;
      const keywordsInput = document.getElementById("keywords") as HTMLInputElement;
      const languageInput = document.querySelector('input[name="targetLanguage"]:checked') as HTMLInputElement;

      const topic = topicInput.value.trim();
      if (!topic) {
        topicInput.focus();
        return;
      }

      const keywords = keywordsInput.value
        .split(",")
        .map((k) => k.trim())
        .filter((k) => k.length > 0);

      const targetLanguage = languageInput.value;

      showLoading();

      try {
        const response = await fetch("/api/blog/generate", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ topic, keywords, targetLanguage }),
        });

        const data = await response.json();

        if (data.success && data.article) {
          showSuccess(data.article.id);
        } else {
          showError(data.error?.message || "Terjadi kesalahan saat membuat artikel. Silakan coba lagi.");
        }
      } catch {
        showError("Tidak dapat terhubung ke server. Periksa koneksi internet Anda.");
      }
    }

    form.addEventListener("submit", (e) => {
      e.preventDefault();
      submitGeneration();
    });

    retryBtn.addEventListener("click", () => {
      submitGeneration();
    });
  </script>
</AdminLayout>
