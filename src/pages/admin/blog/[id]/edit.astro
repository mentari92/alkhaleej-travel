---
/**
 * Blog Article Edit Page (SSR)
 * Allows admin to edit a blog draft/article with rich text editing.
 * Includes option to pair articles as translations of each other.
 * Validates: Requirements 6.3, 6.4, 11.10
 */
export const prerender = false;

import AdminLayout from "@/layouts/AdminLayout.astro";
import BlogEditor from "@/components/admin/BlogEditor.astro";
import { getArticleById, listAllArticles } from "@/lib/db/blog";
import { getDB } from "@/lib/db/connection";

const db = getDB(Astro.locals);
const { id } = Astro.params;

if (!id) {
  return Astro.redirect("/admin/blog");
}

const article = await getArticleById(db, id);

if (!article) {
  return Astro.redirect("/admin/blog");
}

// Get articles in the other language for pairing
const allArticles = await listAllArticles(db);
const otherLanguage = article.language === "id" ? "en" : "id";
const pairableArticles = allArticles.filter(
  (a) => a.language === otherLanguage && a.id !== article.id
);
---

<AdminLayout title={`Edit: ${article.title}`}>
  <div class="max-w-4xl space-y-6">
    <!-- Header -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
      <div>
        <div class="flex items-center gap-2">
          <a href="/admin/blog" class="text-sm text-gray-500 hover:text-gray-700">
            ← Kembali ke daftar
          </a>
        </div>
        <h2 class="mt-2 text-2xl font-bold text-gray-900">Edit Artikel</h2>
        <div class="mt-1 flex items-center gap-2">
          <span class:list={[
            "inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium",
            article.language === "id"
              ? "bg-red-100 text-red-800"
              : "bg-blue-100 text-blue-800"
          ]}>
            {article.language === "id" ? "ID" : "EN"}
          </span>
          <span class:list={[
            "inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium",
            article.status === "published"
              ? "bg-green-100 text-green-800"
              : "bg-yellow-100 text-yellow-800"
          ]}>
            {article.status === "published" ? "Dipublikasi" : "Draf"}
          </span>
        </div>
      </div>
    </div>

    <!-- Blog Editor Component -->
    <BlogEditor article={article} pairableArticles={pairableArticles} />
  </div>
</AdminLayout>
