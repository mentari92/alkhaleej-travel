---
/**
 * Admin Dashboard Index Page (SSR)
 * Shows overview with counts of destinations and blog articles.
 * Validates: Requirements 4.2, 5.3
 */
export const prerender = false;

import AdminLayout from "@/layouts/AdminLayout.astro";
import { getDB } from "@/lib/db/connection";

const db = getDB();

let totalDestinations = 0;
let publishedDestinations = 0;
let draftDestinations = 0;
let totalArticles = 0;
let publishedArticles = 0;
let draftArticles = 0;

if (db) {
  try {
    const destinationCountResult = await db
      .prepare("SELECT COUNT(*) as count FROM packages")
      .first<{ count: number }>();

    const publishedDestinationCountResult = await db
      .prepare("SELECT COUNT(*) as count FROM packages WHERE status = 'published'")
      .first<{ count: number }>();

    const blogCountResult = await db
      .prepare("SELECT COUNT(*) as count FROM blog_articles")
      .first<{ count: number }>();

    const publishedBlogCountResult = await db
      .prepare("SELECT COUNT(*) as count FROM blog_articles WHERE status = 'published'")
      .first<{ count: number }>();

    totalDestinations = destinationCountResult?.count ?? 0;
    publishedDestinations = publishedDestinationCountResult?.count ?? 0;
    draftDestinations = totalDestinations - publishedDestinations;

    totalArticles = blogCountResult?.count ?? 0;
    publishedArticles = publishedBlogCountResult?.count ?? 0;
    draftArticles = totalArticles - publishedArticles;
  } catch (err) {
    console.error("DB Error:", err);
  }
}
---

<AdminLayout title="Dashboard">
  <div class="space-y-6">
    <!-- Welcome section -->
    <div>
      <h2 class="text-2xl font-bold text-gray-900">Selamat Datang</h2>
      <p class="mt-1 text-sm text-gray-600">
        Ringkasan konten Alkhaleej Travel
      </p>
    </div>

    <!-- Stats grid -->
    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
      <!-- Total Destinations -->
      <div class="bg-white rounded-lg border border-gray-200 p-5 shadow-sm">
        <div class="flex items-center">
          <div class="flex-shrink-0 p-3 bg-green-100 rounded-lg">
            <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />
            </svg>
          </div>
          <div class="ml-4">
            <p class="text-sm font-medium text-gray-500">Total Destinasi</p>
            <p class="text-2xl font-semibold text-gray-900">{totalDestinations}</p>
          </div>
        </div>
        <div class="mt-3 text-xs text-gray-500">
          <span class="text-green-600 font-medium">{publishedDestinations} dipublikasi</span>
          {draftDestinations > 0 && (
            <span> · {draftDestinations} draf</span>
          )}
        </div>
      </div>

      <!-- Published Destinations -->
      <div class="bg-white rounded-lg border border-gray-200 p-5 shadow-sm">
        <div class="flex items-center">
          <div class="flex-shrink-0 p-3 bg-blue-100 rounded-lg">
            <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
          </div>
          <div class="ml-4">
            <p class="text-sm font-medium text-gray-500">Destinasi Publik</p>
            <p class="text-2xl font-semibold text-gray-900">{publishedDestinations}</p>
          </div>
        </div>
        <div class="mt-3">
          <a href="/admin/destinations" class="text-xs text-blue-600 hover:text-blue-800 font-medium">
            Kelola destinasi →
          </a>
        </div>
      </div>

      <!-- Total Blog Articles -->
      <div class="bg-white rounded-lg border border-gray-200 p-5 shadow-sm">
        <div class="flex items-center">
          <div class="flex-shrink-0 p-3 bg-purple-100 rounded-lg">
            <svg class="w-6 h-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
          </div>
          <div class="ml-4">
            <p class="text-sm font-medium text-gray-500">Total Artikel</p>
            <p class="text-2xl font-semibold text-gray-900">{totalArticles}</p>
          </div>
        </div>
        <div class="mt-3 text-xs text-gray-500">
          <span class="text-purple-600 font-medium">{publishedArticles} dipublikasi</span>
          {draftArticles > 0 && (
            <span> · {draftArticles} draf</span>
          )}
        </div>
      </div>

      <!-- Published Articles -->
      <div class="bg-white rounded-lg border border-gray-200 p-5 shadow-sm">
        <div class="flex items-center">
          <div class="flex-shrink-0 p-3 bg-orange-100 rounded-lg">
            <svg class="w-6 h-6 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
            </svg>
          </div>
          <div class="ml-4">
            <p class="text-sm font-medium text-gray-500">Artikel Publik</p>
            <p class="text-2xl font-semibold text-gray-900">{publishedArticles}</p>
          </div>
        </div>
        <div class="mt-3">
          <a href="/admin/blog" class="text-xs text-orange-600 hover:text-orange-800 font-medium">
            Kelola blog →
          </a>
        </div>
      </div>
    </div>

    <!-- Quick actions -->
    <div class="bg-white rounded-lg border border-gray-200 p-5 shadow-sm">
      <h3 class="text-lg font-semibold text-gray-900 mb-4">Aksi Cepat</h3>
      <div class="flex flex-wrap gap-3">
        <a
          href="/admin/destinations/new"
          class="inline-flex items-center px-4 py-2.5 text-sm font-medium text-white bg-green-600 hover:bg-green-700 rounded-lg transition-colors min-h-[44px]"
        >
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
          </svg>
          Tambah Destinasi
        </a>
        <a
          href="/admin/blog/generate"
          class="inline-flex items-center px-4 py-2.5 text-sm font-medium text-white bg-purple-600 hover:bg-purple-700 rounded-lg transition-colors min-h-[44px]"
        >
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
          </svg>
          Generate Artikel AI
        </a>
      </div>
    </div>
  </div>
</AdminLayout>
