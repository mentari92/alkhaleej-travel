---
export const prerender = false;

import "@/styles/globals.css";
import { getDB } from "@/lib/db/connection";
import { listPublishedArticles } from "@/lib/db/blog";
import type { PackageRow, DepartureScheduleRow, BlogArticle } from "@/lib/db/schema";

const db = getDB();

// Fetch packages from DB
let packages: PackageRow[] = [];
try {
  const result = await db
    .prepare("SELECT * FROM packages WHERE status = 'published' ORDER BY created_at DESC")
    .all<PackageRow>();
  packages = result.results;
} catch { /* fallback empty */ }

// Fetch departure schedules from DB
let schedules: (DepartureScheduleRow & { pkgTitle: string })[] = [];
try {
  const result = await db
    .prepare(`
      SELECT s.*, p.title_id as pkg_title 
      FROM departure_schedules s 
      JOIN packages p ON s.package_id = p.id 
      WHERE s.status = 'open' 
      ORDER BY s.departure_date ASC
    `)
    .all<DepartureScheduleRow & { pkg_title: string }>();
  schedules = result.results.map(r => ({ ...r, pkgTitle: r.pkg_title }));
} catch { /* fallback empty */ }

// Fetch blog articles from DB
let posts: BlogArticle[] = [];
try {
  posts = (await listPublishedArticles(db, "id")).slice(0, 3);
} catch { /* fallback empty */ }

const formatDate = (dateStr: string) => {
  const d = new Date(dateStr);
  const months = ['JAN','FEB','MAR','APR','MEI','JUN','JUL','AGT','SEP','OKT','NOV','DES'];
  return { day: d.getDate().toString().padStart(2,'0'), month: months[d.getMonth()] };
};
