---
/**
 * Homepage — PT Alkhaleej Travelindo Utama
 * Redesigned based on Google Stitch design.
 */
export const prerender = false;

import BaseLayout from "@/layouts/BaseLayout.astro";
import type { TravelPackage, BlogArticle } from "@/lib/types";
import { mockPackages, mockBlogArticles } from "@/lib/mock-data";
import { getSiteSettings } from "@/lib/db/site-settings";
import { SiteSettingsDefaults } from "@/lib/site-settings/defaults";
import { getDB } from "@/lib/db/connection";

let packages: TravelPackage[] = [];
let blogArticles: BlogArticle[] = [];
const settings = await (async () => {
  try {
    const db = getDB();
    return await getSiteSettings(db);
  } catch {
    return SiteSettingsDefaults;
  }
})();

try {
  const db = getDB();
} catch {}

if (packages.length === 0) packages = mockPackages;
if (blogArticles.length === 0) blogArticles = mockBlogArticles;

const posts = blogArticles.slice(0, 3);

function getPackageTypeLabel(type: string) {
  const labels: Record<string, string> = {
    haji_mujamalah: "HAJI MUJAMALAH",
    umrah: "UMRAH",
  };
  return labels[type] || type.toUpperCase();
}
---

<BaseLayout
  title="Alkhaleej Travelindo Utama — Partner Haji & Umrah Terpercaya"
  description="PT Alkhaleej Travelindo Utama — penyedia paket Haji Mujamalah dan Umrah terpercaya. Pelayanan premium dengan pembimbing ibadah berpengalaman."
  settings={settings}
>
  <!-- Hero Banner -->
  <header class="relative h-[80vh] w-full flex items-center justify-center overflow-hidden mt-0">
    <div class="absolute inset-0 z-0">
      <img alt="Masjidil Haram Makkah" class="w-full h-full object-cover" src="/assets/kaabah-masjidil-haram.jpg" />
      <div class="absolute inset-0 bg-navy-deep/60"></div>
    </div>
    <div class="relative z-10 text-center px-6">
      <h1 class="text-4xl md:text-5xl lg:text-[48px] font-bold text-white mb-4 leading-tight">
        Pilih Perjalanan Suci Anda
      </h1>
      <div class="w-24 h-1 bg-gold-mid mx-auto rounded-full"></div>
      <p class="mt-6 text-white/90 text-lg md:text-xl max-w-2xl mx-auto leading-relaxed">
        Melayani dengan hati, membimbing langkah Anda menuju Baitullah dengan kenyamanan dan kekhusyukan yang tak terlupakan.
      </p>
    </div>
  </header>

  <!-- Mengapa Kami -->
  <section class="py-20 lg:py-28 px-6 lg:px-12 max-w-7xl mx-auto text-center">
    <span class="text-gold-mid text-sm font-semibold uppercase tracking-[0.2em] mb-4 block">Mengapa Kami</span>
    <h2 class="text-3xl md:text-[48px] font-bold text-navy-deep mb-16">Alkhaleej Travelindo Utama</h2>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div class="bg-white p-10 rounded-2xl shadow-sm border border-surface-container hover:shadow-md transition-shadow">
        <div class="w-16 h-16 bg-gold-mid/10 text-gold-mid rounded-full flex items-center justify-center mx-auto mb-6">
          <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
        </div>
        <h3 class="text-xl font-semibold text-navy-deep mb-4">Resmi & Terlisensi</h3>
        <p class="text-muted-foreground text-base">Terdaftar resmi di Kementerian Agama RI sebagai penyelenggara Umrah dan Haji Khusus.</p>
      </div>

      <div class="bg-white p-10 rounded-2xl shadow-sm border border-surface-container hover:shadow-md transition-shadow">
        <div class="w-16 h-16 bg-gold-mid/10 text-gold-mid rounded-full flex items-center justify-center mx-auto mb-6">
          <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
        </div>
        <h3 class="text-xl font-semibold text-navy-deep mb-4">Pembimbing Berpengalaman</h3>
        <p class="text-muted-foreground text-base">Setiap rombongan didampingi pembimbing ibadah bersertifikat dengan pengalaman bertahun-tahun.</p>
      </div>

      <div class="bg-white p-10 rounded-2xl shadow-sm border border-surface-container hover:shadow-md transition-shadow">
        <div class="w-16 h-16 bg-gold-mid/10 text-gold-mid rounded-full flex items-center justify-center mx-auto mb-6">
          <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
        </div>
        <h3 class="text-xl font-semibold text-navy-deep mb-4">Pelayanan 24 Jam</h3>
        <p class="text-muted-foreground text-base">Tim kami siap melayani Anda selama 24 jam di Tanah Suci. Konsultasi dan booking mudah via WhatsApp.</p>
      </div>
    </div>
  </section>

  <!-- Packages Section -->
  <section class="py-16 lg:py-20 px-6 lg:px-12 max-w-[1100px] mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-10 lg:gap-16">
      {packages.map((pkg) => (
        <a href={`/packages/${pkg.slug}`} class="group bg-white rounded-xl overflow-hidden shadow-sm hover:shadow-xl transition-shadow duration-500">
          <div class="relative h-64 overflow-hidden">
            <img alt={pkg.title.id} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" src={pkg.heroImage} loading="lazy" />
            <div class="absolute top-4 left-4 bg-gold-mid text-navy-deep px-4 py-1 rounded-full text-xs font-semibold uppercase tracking-widest shadow-lg">
              {getPackageTypeLabel(pkg.packageType)}
            </div>
          </div>
          <div class="p-8">
            <h3 class="text-2xl lg:text-[32px] font-bold text-navy-deep mb-2">{pkg.title.id}</h3>
            <p class="text-gold-mid text-sm font-semibold uppercase tracking-tight mb-4">{pkg.tagline.id}</p>
            <p class="text-muted-foreground text-base mb-6 line-clamp-2">{pkg.aboutText.id.slice(0, 130)}...</p>
            <div class="flex flex-wrap gap-2 mb-8">
              {pkg.tiers.map((tier, i) => (
                <span class:list={[
                  "px-3 py-1 rounded-full text-xs font-semibold",
                  i === 0 ? "bg-surface-container-high text-navy-deep" : i === 1 ? "bg-primary text-white" : "bg-navy-deep text-gold-warm",
                ]}>
                  {tier.name.id}
                </span>
              ))}
            </div>
            <span class="flex items-center text-gold-mid font-bold hover:gap-4 transition-all duration-300">
              Lihat Detail
              <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
            </span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Jadwal Keberangkatan -->
  <section id="jadwal" class="bg-cream-bg py-16 lg:py-20 islamic-pattern">
    <div class="max-w-7xl mx-auto px-6 lg:px-12">
      <div class="mb-16 text-center">
        <span class="text-gold-mid text-sm font-semibold uppercase tracking-[0.2em] mb-4 block">JADWAL</span>
        <h2 class="text-3xl md:text-[48px] font-bold text-navy-deep">
          Jadwal <span class="text-gold-accent">Keberangkatan</span>
        </h2>
        <p class="mt-4 text-muted-foreground max-w-xl mx-auto">Pilih jadwal keberangkatan yang sesuai dengan rencana perjalanan ibadah Anda.</p>
      </div>

      <div class="max-w-4xl mx-auto space-y-4">
        {packages.flatMap(pkg => pkg.departureSchedules.map(sched => ({ ...sched, pkgTitle: pkg.title, pkgSlug: pkg.slug }))).map((sched) => {
          const d = new Date(sched.departureDate);
          const day = d.getDate().toString().padStart(2, '0');
          const months = ['JAN','FEB','MAR','APR','MEI','JUN','JUL','AGT','SEP','OKT','NOV','DES'];
          const month = months[d.getMonth()];
          return (
            <div class="bg-white p-6 rounded-2xl flex flex-col md:flex-row items-center gap-6 shadow-sm border border-surface-container hover:shadow-md transition-all">
              <div class="flex-shrink-0 w-20 h-20 bg-gold-mid text-white rounded-xl flex flex-col items-center justify-center">
                <span class="text-2xl font-bold">{day}</span>
                <span class="text-xs uppercase tracking-widest">{month}</span>
              </div>
              <div class="flex-grow text-center md:text-left">
                <h4 class="text-xl font-bold text-navy-deep">{sched.pkgTitle.id}</h4>
                <p class="text-muted-foreground flex items-center justify-center md:justify-start gap-2 mt-1">
                  <svg class="w-4 h-4 text-gold-mid shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-2-6.5V5a2 2 0 00-2-2H5a2 2 0 00-2 2v9.5L1 21l9-2zm7-5V5H5v9.5"/></svg>
                  {sched.departureCity.id} · {sched.availableSeats} Kursi Tersisa
                </p>
              </div>
              <div class="flex-shrink-0">
                <a href={`https://wa.me/${settings.primaryWhatsappNumber}?text=Halo, saya tertarik dengan jadwal ${sched.pkgTitle.id} tanggal ${day} ${month}`} class="bg-navy-deep text-gold-mid px-8 py-3 rounded-full font-bold hover:bg-navy-deep/90 transition-colors uppercase text-sm tracking-wider shadow-lg inline-block">
                  Daftar
                </a>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Blog -->
  {posts.length > 0 && (
    <section class="py-20 lg:py-28 px-6 lg:px-12 max-w-7xl mx-auto">
      <div class="flex justify-between items-end mb-12">
        <div>
          <span class="text-gold-mid text-sm font-semibold uppercase tracking-[0.2em] mb-4 block">ARTIKEL</span>
          <h2 class="text-3xl md:text-[48px] font-bold text-navy-deep">Dari Blog Kami</h2>
        </div>
        <a href="/blog" class="text-gold-mid font-semibold flex items-center gap-2 hover:underline text-sm">
          Lihat semua <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {posts.map((p) => (
          <a href={`/blog/${p.slug}`} class="group cursor-pointer">
            <div class="relative aspect-[4/3] rounded-2xl overflow-hidden mb-6 bg-surface-container">
              {p.thumbnailUrl ? (
                <img src={p.thumbnailUrl} alt={p.title} class="w-full h-full object-cover" loading="lazy" />
              ) : (
                <div class="w-full h-full flex items-center justify-center">
                  <svg class="w-16 h-16 text-gold-mid/30" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                </div>
              )}
            </div>
            <h4 class="text-lg font-semibold text-navy-deep mb-3 group-hover:text-gold-mid transition-colors">{p.title}</h4>
            <p class="text-muted-foreground text-base line-clamp-2">{p.excerpt}</p>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- CTA Section -->
  <section class="py-16 lg:py-20 max-w-7xl mx-auto px-6 lg:px-12">
    <div class="relative bg-gradient-to-br from-[#1b4332] to-[#081c15] rounded-3xl p-10 md:p-16 overflow-hidden shadow-2xl flex flex-col md:flex-row items-center justify-between gap-10">
      <div class="relative z-10 max-w-xl text-center md:text-left">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Siap Menunaikan Ibadah?</h2>
        <p class="text-white/80 text-lg">
          Tim kami siap membantu Anda mewujudkan perjalanan suci impian. Konsultasi gratis via WhatsApp.
        </p>
      </div>
      <div class="relative z-10 flex flex-col sm:flex-row items-center gap-4 flex-shrink-0">
        <a href={`https://wa.me/${settings.primaryWhatsappNumber}`} class="bg-[#c6a554] text-[#0F0F1B] font-bold px-8 py-3.5 rounded-full flex items-center gap-3 hover:scale-105 transition-all shadow-lg text-sm uppercase tracking-wider">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Hubungi Kami Sekarang
        </a>
        <a href="/packages" class="border border-white/40 text-white font-bold px-8 py-3.5 rounded-full hover:bg-white/10 transition-all text-sm uppercase tracking-wider">
          Lihat Paket
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
