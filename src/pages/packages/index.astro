---
/**
 * Packages listing page — PT Alkhaleej Travelindo Utama
 */
export const prerender = false;

import BaseLayout from "@/layouts/BaseLayout.astro";
import { mockPackages } from "@/lib/mock-data";
import { getSiteSettings } from "@/lib/db/site-settings";
import { SiteSettingsDefaults } from "@/lib/site-settings/defaults";
import { getDB } from "@/lib/db/connection";

const settings = await (async () => {
  try {
    const db = getDB();
    return await getSiteSettings(db);
  } catch {
    return SiteSettingsDefaults;
  }
})();

let packages = mockPackages;

function getPackageTypeLabel(type: string) {
  const labels: Record<string, string> = {
    haji_mujamalah: "Haji Mujamalah",
    umrah: "Umrah",
    umrah_plus: "Umrah Plus",
    tour_muslim: "Tour Muslim",
  };
  return labels[type] || type;
}

function getPackageTypeIcon(type: string) {
  if (type === "haji_mujamalah") return "🕋";
  if (type === "umrah") return "🕌";
  if (type === "umrah_plus") return "✈️";
  return "🌍";
}
---

<BaseLayout
  title="Paket Haji & Umrah — Alkhaleej Travelindo Utama"
  description="Pilihan paket Haji Mujamalah, Umrah, Umrah Plus Turki, dan Tour Muslim Eropa dari PT Alkhaleej Travelindo Utama."
  settings={settings}
>
  <!-- Hero -->
  <section class="relative bg-navy text-white py-20 mt-16 md:mt-20 overflow-hidden">
    <img src="/assets/kaabah-masjidil-haram.jpg" alt="Masjidil Haram Makkah" class="absolute inset-0 w-full h-full object-cover" loading="eager" />
    <div class="absolute inset-0 bg-navy/70"></div>
    <div class="container-page text-center relative z-10">
      <p class="text-sm font-semibold text-gold uppercase tracking-wider mb-3">Paket Kami</p>
      <h1 class="font-display font-bold text-4xl md:text-6xl">
        Pilih <span class="text-gradient-gold">Perjalanan Suci</span> Anda
      </h1>
      <p class="mt-4 text-lg text-white/70 max-w-2xl mx-auto">
        Paket Haji Mujamalah dan Umrah dengan pelayanan premium, pembimbing ibadah berpengalaman, dan akomodasi terbaik di Tanah Suci.
      </p>
    </div>
  </section>

  <!-- Packages Grid -->
  <section class="container-page py-16">
    <div class="grid md:grid-cols-2 gap-10 max-w-5xl mx-auto">
      {packages.map((pkg) => (
        <a
          href={`/packages/${pkg.slug}`}
          class="group relative flex flex-col rounded-3xl overflow-hidden bg-card border border-border shadow-soft hover:shadow-card transition-all hover:-translate-y-1"
        >
          <!-- Image area -->
          <div class="relative aspect-[16/9] overflow-hidden bg-navy">
            <img src={pkg.heroImage} alt={pkg.title.id} class="absolute inset-0 w-full h-full object-cover" loading="lazy" />
            <div class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-navy/90 z-10"></div>
            <!-- Badge -->
            <div class="absolute top-4 left-4 z-20">
              <span class="px-4 py-1.5 rounded-full bg-gold/90 text-navy text-xs font-bold uppercase tracking-wider">
                {getPackageTypeLabel(pkg.packageType)}
              </span>
            </div>
            <!-- Title overlay -->
            <div class="absolute bottom-0 left-0 right-0 p-6 text-white z-20">
              <h2 class="font-display font-bold text-3xl">{pkg.title.id}</h2>
              <p class="text-white/80 mt-1">{pkg.tagline.id}</p>
            </div>
          </div>

          <!-- Content -->
          <div class="p-6">
            <p class="text-sm text-muted-foreground line-clamp-2 mb-4">{pkg.aboutText.id}</p>

            <!-- Tiers preview -->
            <div class="space-y-3 mb-6">
              {pkg.tiers.slice(0, 3).map((tier) => (
                <div class="flex items-center justify-between p-3 rounded-xl bg-secondary/50">
                  <div class="flex items-center gap-3">
                    <span class="text-sm font-semibold">{tier.name.id}</span>
                    {tier.hotelRating && (
                      <span class="text-xs text-gold">★ {tier.hotelRating}★ Hotel</span>
                    )}
                  </div>
                  <span class="font-display font-bold text-gold">{tier.price}</span>
                </div>
              ))}
            </div>

            <!-- Footer -->
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-2 text-sm text-muted-foreground">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
                </svg>
                {pkg.departureSchedules.length} jadwal tersedia
              </div>
              <span class="inline-flex items-center gap-1 text-sm font-medium text-gold group-hover:underline">
                Lihat Detail
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
                </svg>
              </span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Jadwal Keberangkatan -->
  <section id="jadwal" class="bg-cream py-20">
    <div class="container-page">
      <div class="text-center mb-12">
        <p class="text-sm font-semibold text-gold uppercase tracking-wider mb-3">Jadwal</p>
        <h2 class="font-display font-bold text-4xl md:text-5xl text-navy">
          Jadwal Keberangkatan Terbaru
        </h2>
      </div>

      <div class="max-w-3xl mx-auto space-y-4">
        {packages.flatMap(pkg => pkg.departureSchedules.map(sched => ({ ...sched, pkgTitle: pkg.title, pkgSlug: pkg.slug }))).map((sched) => (
          <div class="flex items-center justify-between p-5 rounded-2xl bg-card border border-border shadow-soft">
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 rounded-xl bg-gold/10 flex items-center justify-center shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-gold" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
                </svg>
              </div>
              <div>
                <p class="font-display font-bold text-navy">{sched.pkgTitle.id}</p>
                <p class="text-sm text-muted-foreground">
                  {sched.departureCity.id} · {new Date(sched.departureDate).toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' })}
                  {sched.returnDate && ` — ${new Date(sched.returnDate).toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' })}`}
                </p>
              </div>
            </div>
            <div class="text-right shrink-0">
              {sched.availableSeats > 0 ? (
                <span class="px-3 py-1 rounded-full bg-emerald/10 text-emerald text-sm font-medium">
                  {sched.availableSeats} kursi
                </span>
              ) : (
                <span class="px-3 py-1 rounded-full bg-destructive/10 text-destructive text-sm font-medium">
                  Penuh
                </span>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
