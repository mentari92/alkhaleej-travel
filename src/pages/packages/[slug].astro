---
/**
 * Package detail page — PT Alkhaleej Travelindo Utama
 */
export const prerender = false;

import BaseLayout from "@/layouts/BaseLayout.astro";
import { mockPackages } from "@/lib/mock-data";
import { getSiteSettings } from "@/lib/db/site-settings";
import { SiteSettingsDefaults } from "@/lib/site-settings/defaults";
import { getDB } from "@/lib/db/connection";

const { slug } = Astro.params;

const settings = await (async () => {
  try {
    const db = getDB();
    return await getSiteSettings(db);
  } catch {
    return SiteSettingsDefaults;
  }
})();

let packages = mockPackages;
const pkg = packages.find(p => p.slug === slug);

if (!pkg) {
  return Astro.redirect("/404");
}

const otherPackages = packages.filter(p => p.slug !== slug).slice(0, 3);
---

<BaseLayout
  title={`${pkg.title.id} — Alkhaleej Travelindo Utama`}
  description={pkg.aboutText.id}
  settings={settings}
>
  <!-- Hero -->
  <section class="relative min-h-[60vh] flex items-end overflow-hidden bg-navy">
    <div class="absolute inset-0 bg-pattern-islamic opacity-30"></div>
    <div class="absolute inset-0" style="background: var(--gradient-hero);"></div>
    <div class="container-page relative pb-16 pt-32 text-white z-10">
      <a href="/packages" class="inline-flex items-center gap-2 text-sm text-white/60 hover:text-gold transition mb-6">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m12 19-7-7 7-7"/><path d="M19 12H5"/>
        </svg>
        Kembali ke Paket
      </a>
      <h1 class="font-display font-bold text-5xl md:text-7xl">{pkg.title.id}</h1>
      <p class="mt-4 text-xl text-white/80 max-w-2xl">{pkg.tagline.id}</p>
      <div class="mt-6 flex flex-wrap gap-3">
        {pkg.tiers[0] && (
          <span class="px-4 py-2 rounded-full bg-gold text-navy font-bold">
            Mulai {pkg.tiers[0].price}
          </span>
        )}
        <a href={`https://wa.me/${pkg.whatsappNumber}`} class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-whatsapp text-white font-semibold hover:bg-whatsapp/90 transition">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Booking Sekarang
        </a>
      </div>
    </div>
  </section>

  <!-- About -->
  <section class="container-page py-16">
    <div class="max-w-3xl">
      <h2 class="font-display font-bold text-3xl text-navy mb-6">Tentang Paket Ini</h2>
      <p class="text-lg text-muted-foreground leading-relaxed">{pkg.aboutText.id}</p>
    </div>
  </section>

  <!-- Package Tiers / Pricing -->
  <section class="bg-cream py-16">
    <div class="container-page">
      <h2 class="font-display font-bold text-3xl text-navy text-center mb-12">Pilihan Paket</h2>
      <div class="grid md:grid-cols-3 gap-6">
        {pkg.tiers.map((tier) => (
          <div class="bg-card rounded-3xl p-8 border border-border shadow-soft hover:shadow-card transition relative overflow-hidden">
            <h3 class="font-display font-bold text-2xl text-navy">{tier.name.id}</h3>
            <p class="text-sm text-muted-foreground mt-1">{tier.description.id}</p>
            <div class="mt-6">
              <p class="font-display font-bold text-4xl text-gold">{tier.price}</p>
              <p class="text-sm text-muted-foreground">{tier.duration.id}</p>
            </div>
            {tier.hotelRating && (
              <div class="mt-4 flex items-center gap-1 text-gold">
                {Array.from({length: parseInt(tier.hotelRating)}).map(() => (
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                ))}
                <span class="text-xs text-muted-foreground ml-1">{tier.hotelRating}★ Hotel</span>
              </div>
            )}
            <ul class="mt-6 space-y-3">
              {tier.features.map((f) => (
                <li class="flex items-start gap-2 text-sm">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-emerald shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M20 6 9 17l-5-5"/>
                  </svg>
                  {f.id}
                </li>
              ))}
            </ul>
            <a href={`https://wa.me/${pkg.whatsappNumber}?text=Halo, saya tertarik dengan paket ${pkg.title.id} - ${tier.name.id}`} class="mt-8 block text-center px-6 py-3 rounded-full bg-gold text-navy font-bold hover:bg-gold-light transition">
              Pilih Paket Ini
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Departure Schedules -->
  {pkg.departureSchedules.length > 0 && (
    <section class="container-page py-16">
      <h2 class="font-display font-bold text-3xl text-navy text-center mb-12">Jadwal Keberangkatan</h2>
      <div class="max-w-3xl mx-auto space-y-4">
        {pkg.departureSchedules.map((sched) => (
          <div class="flex items-center justify-between p-5 rounded-2xl bg-card border border-border shadow-soft">
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 rounded-xl bg-gold/10 flex items-center justify-center shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-gold" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
                </svg>
              </div>
              <div>
                <p class="font-semibold text-navy">{sched.departureCity.id}</p>
                <p class="text-sm text-muted-foreground">
                  {new Date(sched.departureDate).toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' })}
                  {sched.returnDate && ` — ${new Date(sched.returnDate).toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' })}`}
                </p>
              </div>
            </div>
            <div class="text-right">
              {sched.availableSeats > 0 ? (
                <span class="px-3 py-1 rounded-full bg-emerald/10 text-emerald text-sm font-medium">
                  {sched.availableSeats} kursi tersisa
                </span>
              ) : (
                <span class="px-3 py-1 rounded-full bg-destructive/10 text-destructive text-sm font-medium">
                  Penuh
                </span>
              )}
            </div>
          </div>
        ))}
      </div>
    </section>
  )}

  <!-- Testimonials -->
  {pkg.testimonials.length > 0 && (
    <section class="bg-cream py-16">
      <div class="container-page">
        <h2 class="font-display font-bold text-3xl text-navy text-center mb-12">Testimoni Jamaah</h2>
        <div class="grid md:grid-cols-2 gap-6 max-w-3xl mx-auto">
          {pkg.testimonials.map((testi) => (
            <div class="bg-card rounded-3xl p-8 shadow-soft">
              <div class="flex items-center gap-1 text-gold mb-4">
                {Array.from({length: testi.rating}).map(() => (
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                ))}
              </div>
              <p class="text-foreground leading-relaxed">"{testi.content.id}"</p>
              <div class="mt-4 flex items-center gap-3">
                <div class="w-10 h-10 rounded-full bg-gold/20 flex items-center justify-center text-gold font-bold text-sm">
                  {testi.author.charAt(0)}
                </div>
                <div>
                  <p class="font-semibold text-sm">{testi.author}</p>
                  <p class="text-xs text-muted-foreground">{testi.originCity}{testi.year ? ` · ${testi.year}` : ''}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- FAQ -->
  {pkg.faqEntries.length > 0 && (
    <section class="container-page py-16">
      <h2 class="font-display font-bold text-3xl text-navy text-center mb-12">Pertanyaan Umum</h2>
      <div class="max-w-3xl mx-auto space-y-4">
        {pkg.faqEntries.map((faq) => (
          <div class="p-6 rounded-2xl bg-card border border-border shadow-soft">
            <h3 class="font-display font-bold text-lg text-navy">{faq.question.id}</h3>
            <p class="mt-3 text-muted-foreground leading-relaxed">{faq.answer.id}</p>
          </div>
        ))}
      </div>
    </section>
  )}

  <!-- Other Packages -->
  {otherPackages.length > 0 && (
    <section class="bg-cream py-16">
      <div class="container-page">
        <h2 class="font-display font-bold text-3xl text-navy text-center mb-12">Paket Lainnya</h2>
        <div class="grid md:grid-cols-3 gap-6">
          {otherPackages.map((other) => (
            <a href={`/packages/${other.slug}`} class="group rounded-3xl overflow-hidden bg-card border border-border shadow-soft hover:shadow-card transition">
              <div class="aspect-[5/3] bg-navy flex items-center justify-center relative">
                <span class="text-4xl opacity-40">
                  {other.packageType === "haji_mujamalah" ? "🕋" : other.packageType === "umrah" ? "🕌" : "✈️"}
                </span>
              </div>
              <div class="p-5">
                <h3 class="font-display font-bold text-xl text-navy group-hover:text-gold transition">{other.title.id}</h3>
                <p class="text-sm text-muted-foreground mt-1">{other.tagline.id}</p>
                <p class="font-display font-bold text-gold mt-3">{other.tiers[0]?.price || "Hubungi kami"}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="container-page py-16">
    <div class="relative overflow-hidden rounded-3xl p-10 text-white text-center" style="background: linear-gradient(135deg, hsl(220 45% 12%) 0%, hsl(37 62% 36%) 100%);">
      <div class="absolute -right-20 -top-20 w-80 h-80 rounded-full bg-gold/30 blur-3xl"></div>
      <div class="relative">
        <h2 class="font-display font-bold text-3xl md:text-4xl">Tertarik dengan {pkg.title.id}?</h2>
        <p class="mt-3 text-white/80">Konsultasi gratis dengan tim kami via WhatsApp</p>
        <a href={`https://wa.me/${pkg.whatsappNumber}?text=Halo, saya tertarik dengan paket ${pkg.title.id}`} class="mt-6 inline-flex items-center gap-2 px-8 py-4 rounded-full bg-gold text-navy font-bold text-lg hover:bg-gold-light transition">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Hubungi Kami Sekarang
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
