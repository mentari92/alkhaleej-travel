      <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">{pkg.title_id}</h1>
      <p class="text-[#C6A554] text-lg font-semibold">{pkg.tagline_id}</p>
    </div>
  </header>

  <!-- About -->
  <section class="py-16 px-6 lg:px-12 max-w-[800px] mx-auto text-center">
