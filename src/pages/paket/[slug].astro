---
export const prerender = false;

import "@/styles/globals.css";
import { getDB } from "@/lib/db/connection";
import type { PackageRow, PackageTierRow, DepartureScheduleRow } from "@/lib/db/schema";

const db = getDB();
const { slug } = Astro.params;

let pkg: PackageRow | null = null;
let tiers: PackageTierRow[] = [];
let schedules: DepartureScheduleRow[] = [];

try {
  pkg = await db
    .prepare("SELECT * FROM packages WHERE slug = ? AND status = 'published'")
    .bind(slug)
    .first<PackageRow>();

  if (pkg) {
    const tiersResult = await db
      .prepare("SELECT * FROM package_tiers WHERE package_id = ? ORDER BY sort_order")
      .bind(pkg.id)
      .all<PackageTierRow>();
    tiers = tiersResult.results;

    const schedResult = await db
      .prepare("SELECT * FROM departure_schedules WHERE package_id = ? AND status = 'open' ORDER BY departure_date")
      .bind(pkg.id)
      .all<DepartureScheduleRow>();
    schedules = schedResult.results;
  }
} catch { /* empty */ }

if (!pkg) {
  return Astro.redirect("/paket");
}

const formatDate = (d: string) => {
  const dt = new Date(d);
  return dt.toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' });
};
---
<!doctype html>
<html lang="id">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
