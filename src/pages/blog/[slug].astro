---
export const prerender = false;

import "@/styles/globals.css";
import { getDB } from "@/lib/db/connection";
import { getArticleBySlug } from "@/lib/db/blog";

const db = getDB();
const { slug } = Astro.params;

let article: any = null;
try {
  article = await getArticleBySlug(db, slug);
} catch { /* empty */ }

if (!article) {
  return Astro.redirect("/blog");
}
---
<!doctype html>
<html lang="id">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{article.title} — Alkhaleej Travelindo Utama</title>
  <meta name="description" content={article.metaDescription || article.excerpt} />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="icon" type="image/svg+xml" href="/logo.svg" />
</head>
<body class="bg-[#fbf9f5] text-[#1b1c1a] font-sans antialiased">

<nav class="fixed top-0 w-full z-50 bg-white/80 backdrop-blur-md border-b border-[#e4e2de]">
  <div class="flex justify-between items-center max-w-[1200px] mx-auto px-6 lg:px-12 py-4">
    <a href="/" class="text-xl md:text-2xl font-bold text-[#0F0F1B]">Alkhaleej Travelindo Utama</a>
    <div class="hidden md:flex space-x-6 items-center">
      <a class="text-xs uppercase tracking-wider text-[#0F0F1B] hover:text-[#C6A554] transition-colors" href="/paket">Paket</a>
      <a class="text-xs uppercase tracking-wider text-[#C6A554] font-bold border-b-2 border-[#C6A554] pb-1" href="/blog">Blog</a>
    </div>
    <a href="https://wa.me/966563317582" class="bg-[#0F0F1B] text-[#C6A554] px-6 py-2 rounded-lg text-sm font-semibold hover:opacity-80 transition-all">Hubungi Kami</a>
  </div>
</nav>

<div class="pt-24">
  <article class="py-16 px-6 lg:px-12 max-w-[800px] mx-auto">
    <a href="/blog/" class="text-[#C6A554] text-sm font-semibold flex items-center gap-2 mb-8 hover:underline">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
      Kembali ke Blog
    </a>

    {article.thumbnailUrl && (
      <div class="aspect-[16/9] rounded-2xl overflow-hidden mb-8">
        <img src={article.thumbnailUrl} alt={article.title} class="w-full h-full object-cover" />
      </div>
    )}

    <h1 class="text-3xl md:text-4xl font-bold text-[#0F0F1B] mb-4">{article.title}</h1>

    {article.publishedAt && (
      <p class="text-[#504537] text-sm mb-8">
        {new Date(article.publishedAt).toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' })}
      </p>
    )}

    <div class="prose prose-lg max-w-none text-[#504537] leading-relaxed" set:html={article.content} />
  </article>
</div>

<footer class="bg-[#332b12] text-[#fdfbf7] pt-12 pb-8">
  <div class="max-w-[1200px] mx-auto px-6 lg:px-12">
    <div class="text-2xl font-bold text-white mb-4">Alkhaleej Travelindo Utama</div>
    <p class="text-[#fdfbf7]/70 text-sm">Jl. Bangka Raya RT.011/011, Kec. Mampang Prapatan, Jakarta Selatan, DKI Jakarta 12720</p>
  </div>
  <div class="bg-black/20 py-6 px-6 mt-8">
    <p class="text-[#fdfbf7]/40 text-[10px] text-center tracking-[0.2em] uppercase font-bold">© 2024 ALKHALEEJ TRAVELINDO UTAMA. ALL RIGHTS RESERVED.</p>
  </div>
</footer>

</body>
</html>
