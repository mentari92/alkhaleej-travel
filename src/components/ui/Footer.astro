---
/**
 * Footer — Alkhaleej Travelindo Utama
 * Dark footer matching Google Stitch design.
 */
import { getSiteSettings } from "@/lib/db/site-settings";
import { SiteSettingsDefaults } from "@/lib/site-settings/defaults";
import { getDB } from "@/lib/db/connection";

const settings = await (async () => {
  try {
    const db = getDB();
    return await getSiteSettings(db);
  } catch {
    return SiteSettingsDefaults;
  }
})();
---

<footer class="bg-[#332b12] text-[#fdfbf7] pt-16 lg:pt-20 overflow-hidden">
  <div class="max-w-7xl mx-auto px-6 lg:px-12 pb-16">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12">
      <!-- Brand -->
      <div class="space-y-6">
        <div class="text-2xl text-white font-bold">
          Alkhaleej Travelindo Utama
        </div>
        <p class="text-[#fdfbf7]/70 text-sm leading-relaxed">
          Penyelenggara perjalanan Umrah dan Haji Khusus profesional dengan fokus pada kenyamanan dan kesesuaian syariat.
        </p>
        <div class="flex gap-4">
          {settings.socialInstagramUrl && (
            <a href={settings.socialInstagramUrl} target="_blank" class="w-10 h-10 rounded-full border border-white/20 flex items-center justify-center hover:bg-gold-mid hover:border-gold-mid transition-all group">
              <svg class="w-4 h-4 group-hover:text-[#332b12]" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
            </a>
          )}
          <a href="#" class="w-10 h-10 rounded-full border border-white/20 flex items-center justify-center hover:bg-gold-mid hover:border-gold-mid transition-all group">
            <svg class="w-4 h-4 group-hover:text-[#332b12]" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/></svg>
          </a>
        </div>
      </div>

      <!-- Paket Kami -->
      <div>
        <h5 class="text-white font-bold mb-8 text-sm uppercase tracking-widest">Paket Kami</h5>
        <ul class="space-y-4 text-[#fdfbf7]/70 text-sm">
          <li><a class="hover:text-gold-mid transition-colors" href="/packages/haji-mujamalah">Haji Mujamalah</a></li>
          <li><a class="hover:text-gold-mid transition-colors" href="/packages/umrah">Umrah Silver</a></li>
          <li><a class="hover:text-gold-mid transition-colors" href="/packages/umrah">Umrah Gold</a></li>
          <li><a class="hover:text-gold-mid transition-colors" href="/packages/umrah">Umrah Platinum</a></li>
        </ul>
      </div>

      <!-- Navigasi -->
      <div>
        <h5 class="text-white font-bold mb-8 text-sm uppercase tracking-widest">Navigasi</h5>
        <ul class="space-y-4 text-[#fdfbf7]/70 text-sm">
          <li><a class="hover:text-gold-mid transition-colors" href="/packages#jadwal">Jadwal Keberangkatan</a></li>
          <li><a class="hover:text-gold-mid transition-colors" href="/blog">Blog & Panduan</a></li>
          <li><a class="hover:text-gold-mid transition-colors" href="/about">Tentang Kami</a></li>
          <li><a class="hover:text-gold-mid transition-colors" href="#">Syarat & Ketentuan</a></li>
        </ul>
      </div>

      <!-- Kantor Pusat -->
      <div>
        <h5 class="text-white font-bold mb-8 text-sm uppercase tracking-widest">Kantor Pusat</h5>
        <ul class="space-y-5 text-[#fdfbf7]/70 text-sm">
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-gold-mid shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            <span class="leading-relaxed">{settings.address}</span>
          </li>
          <li class="flex items-center gap-3">
            <svg class="w-5 h-5 text-gold-mid shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            <span>+966 56 331 7582</span>
          </li>
          <li class="flex items-center gap-3">
            <svg class="w-5 h-5 text-gold-mid shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            <span>{settings.supportEmail}</span>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <div class="bg-black/20 py-8 px-6">
    <p class="text-[#fdfbf7]/40 text-[10px] text-center tracking-[0.2em] uppercase font-bold max-w-7xl mx-auto">
      © 2024 ALKHALEEJ TRAVELINDO UTAMA. ALL SPIRITUAL JOURNEYS GUIDED WITH EXCELLENCE.
    </p>
  </div>
</footer>
