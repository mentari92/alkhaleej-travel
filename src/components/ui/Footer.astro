---
/**
 * Footer — Alkhaleej Travelindo Utama
 * Dark footer matching the desired design.
 */
import { SiteSettingsDefaults } from "@/lib/site-settings/defaults";

const settings = SiteSettingsDefaults;
---

<footer class="bg-[var(--brand-green)] text-white pt-16 lg:pt-24">
  <div class="max-w-7xl mx-auto px-6 lg:px-12 pb-20">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-16 lg:gap-24">
      <!-- Brand -->
      <div class="space-y-8">
        <h3 class="text-xl font-bold leading-tight">
          Alkhaleej Travelindo Utama
        </h3>
        <p class="text-white/50 text-[13px] leading-relaxed">
          Penyelenggara perjalanan Umrah dan Haji Khusus profesional dengan fokus pada kenyamanan dan kesesuaian syariat.
        </p>
        <div class="flex gap-4">
          <a href="#" class="w-8 h-8 rounded-full bg-white/10 flex items-center justify-center hover:bg-[var(--gold-mid)] transition-all">
            <!-- Facebook Icon -->
            <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M22.675 0h-21.35c-.732 0-1.325.593-1.325 1.325v21.351c0 .731.593 1.324 1.325 1.324h11.495v-9.294h-3.128v-3.622h3.128v-2.671c0-3.1 1.893-4.788 4.659-4.788 1.325 0 2.463.099 2.795.143v3.24l-1.918.001c-1.504 0-1.795.715-1.795 1.763v2.313h3.587l-.467 3.622h-3.12v9.293h6.116c.73 0 1.323-.593 1.323-1.325v-21.35c0-.732-.593-1.325-1.325-1.325z"/></svg>
          </a>
          <a href="#" class="w-8 h-8 rounded-full bg-white/10 flex items-center justify-center hover:bg-[var(--gold-mid)] transition-all">
            <!-- Instagram Icon -->
            <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
          </a>
        </div>
      </div>

      <!-- Layanan Utama -->
      <div>
        <h5 class="text-white font-bold mb-8 text-[11px] uppercase tracking-[0.3em]">Layanan Utama</h5>
        <ul class="space-y-4 text-white/70 text-[13px]">
          <li><a class="hover:text-[var(--gold-mid)] transition-colors" href="/paket/haji-mujamalah">Paket Haji</a></li>
          <li><a class="hover:text-[var(--gold-mid)] transition-colors" href="/paket/umrah">Paket Umrah</a></li>
          <li><span class="text-white/40 cursor-default">Pengurusan Visa & Tiket</span></li>
        </ul>
      </div>

      <!-- Pusat Bantuan -->
      <div>
        <h5 class="text-white font-bold mb-8 text-[11px] uppercase tracking-[0.3em]">Pusat Bantuan</h5>
        <ul class="space-y-4 text-white/70 text-[13px]">
          <li><a class="hover:text-[var(--gold-mid)] transition-colors" href="/blog">Blog</a></li>
          <li><a class="hover:text-[var(--gold-mid)] transition-colors" href="/tentang-kami">Tentang Kami</a></li>
          <li><a class="hover:text-[var(--gold-mid)] transition-colors" href="#">Syarat dan Ketentuan</a></li>
          <li><a class="hover:text-[var(--gold-mid)] transition-colors" href="#">Kebijakan Privasi</a></li>
        </ul>
      </div>

      <!-- Kantor Pusat -->
      <div>
        <h5 class="text-white font-bold mb-8 text-[11px] uppercase tracking-[0.3em]">Kantor Pusat</h5>
        <ul class="space-y-6 text-white/70 text-[13px]">
          <li class="flex items-start gap-4">
            <svg class="w-4 h-4 text-[var(--gold-mid)] shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            <span class="leading-relaxed">Jl. Bangka Raya<br/>RT.011/011, Kec. Mampang Prapatan,<br/>Jakarta Selatan, DKI Jakarta 12720</span>
          </li>
          <li class="flex items-center gap-4">
            <svg class="w-4 h-4 text-[var(--gold-mid)] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            <span>+966 56 331 7582</span>
          </li>
          <li class="flex items-center gap-4">
            <svg class="w-4 h-4 text-[var(--gold-mid)] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            <span>fifi@travelindo-utama.com</span>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <div class="border-t border-white/5 py-8 text-center flex flex-col md:flex-row justify-between items-center max-w-7xl mx-auto px-6 lg:px-12 gap-4">
    <p class="text-white/40 text-[10px] font-bold uppercase tracking-[0.2em] mb-0">
      © ALKHALEEJ TRAVELINDO UTAMA. ALL RIGHTS RESERVED.
    </p>
    <p class="text-white/40 text-[10px] font-bold uppercase tracking-[0.2em] mb-0">
      CREATED WITH ❤️ BY MENTARICH LLC FROM NEW MEXICO, USA.
    </p>
  </div>
</footer>

