---
/**
 * Header — Alkhaleej Travelindo Utama
 * Clean sticky header matching the desired design.
 */
import { SiteSettingsDefaults } from "@/lib/site-settings/defaults";

const settings = SiteSettingsDefaults;

const navItems = [
  { label: "Home", href: "/" },
  { label: "Paket Haji", href: "/paket/haji-mujamalah" },
  { label: "Paket Umrah", href: "/paket/umrah" },
  { label: "Blog", href: "/blog" },
  { label: "Tentang Kami", href: "/tentang-kami" },
];

const currentPath = Astro.url.pathname;
---

<nav class="fixed top-0 w-full z-50 glass-header">
  <div class="flex justify-between items-center max-w-7xl mx-auto px-6 lg:px-12 py-5">
    <a href="/" class="flex items-center">
      <img src="/logo-new.jpg" alt="Alkhaleej Travelindo Utama" class="h-10 lg:h-12 w-auto rounded-lg shadow-sm object-contain" />
    </a>

    <div class="hidden md:flex space-x-10 items-center">
      {navItems.map((item) => {
        const isActive = currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href));
        return (
          <a
            href={item.href}
            class:list={[
              "text-[11px] uppercase tracking-[0.2em] font-bold transition-all hover:text-[var(--gold-mid)]",
              isActive ? "text-[var(--gold-mid)]" : "text-[var(--navy-deep)]/70",
            ]}
          >
            {item.label}
          </a>
        );
      })}
    </div>

    <a
      href={`https://wa.me/${settings.primaryWhatsappNumber}`}
      class="hidden sm:inline-flex btn-premium-dark"
    >
      Hubungi Kami
    </a>

    <button id="mobile-menu-btn" class="md:hidden p-2 text-[var(--navy-deep)]" aria-label="Menu">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </button>
  </div>

  <div id="mobile-menu" class="hidden md:hidden border-t border-black/5 bg-white shadow-2xl">
    <div class="px-6 py-8 space-y-4">
      {navItems.map((item) => (
        <a href={item.href} class="block text-sm font-bold uppercase tracking-widest text-[var(--navy-deep)] hover:text-[var(--gold-mid)]">
          {item.label}
        </a>
      ))}
      <a href={`https://wa.me/${settings.primaryWhatsappNumber}`} class="block btn-premium-dark w-full text-center mt-6">
        WhatsApp Kami
      </a>
    </div>
  </div>
</nav>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>

