---
/**
 * Header — Alkhaleej Travelindo Utama
 * Clean sticky header matching Google Stitch design.
 */
import { getSiteSettings } from "@/lib/db/site-settings";
import { SiteSettingsDefaults } from "@/lib/site-settings/defaults";
import { getDB } from "@/lib/db/connection";

const settings = await (async () => {
  try {
    const db = getDB();
    return await getSiteSettings(db);
  } catch {
    return SiteSettingsDefaults;
  }
})();

const navItems = [
  { label: "Paket Umrah", href: "/packages" },
  { label: "Haji Khusus", href: "/packages/haji-mujamalah" },
  { label: "Blog", href: "/blog" },
  { label: "Tentang Kami", href: "/about" },
];
---

<nav class="fixed top-0 w-full z-50 bg-white/80 backdrop-blur-md border-b border-surface-container-highest">
  <div class="flex justify-between items-center max-w-7xl mx-auto px-6 lg:px-12 py-4">
    <a href="/" class="flex items-center gap-2">
      <img src="/logo.svg" alt="Alkhaleej Travelindo Utama" class="h-10 lg:h-11 w-auto" />
    </a>

    <div class="hidden md:flex space-x-6 items-center">
      {navItems.map((item, i) => (
        <a
          href={item.href}
          class:list={[
            "text-xs uppercase tracking-wider font-semibold transition-colors",
            i === 0
              ? "text-gold-mid border-b-2 border-gold-mid pb-1"
              : "text-navy-deep hover:text-gold-mid",
          ]}
        >
          {item.label}
        </a>
      ))}
    </div>

    <a
      href={`https://wa.me/${settings.primaryWhatsappNumber}`}
      class="hidden sm:inline-flex bg-navy-deep text-gold-mid px-6 py-2 rounded-lg text-sm font-semibold hover:opacity-80 transition-all active:scale-95"
    >
      Hubungi Kami
    </a>

    <button id="mobile-menu-btn" class="md:hidden p-2 text-navy-deep hover:bg-gray-100 rounded-lg" aria-label="Menu">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </button>
  </div>

  <div id="mobile-menu" class="hidden md:hidden border-t border-surface-container-highest bg-white">
    <div class="px-6 py-4 space-y-1">
      {navItems.map((item) => (
        <a href={item.href} class="block px-4 py-3 text-sm font-medium text-navy-deep hover:text-gold-mid hover:bg-amber-50 rounded-lg transition">
          {item.label}
        </a>
      ))}
      <a href={`https://wa.me/${settings.primaryWhatsappNumber}`} class="block px-4 py-3 text-sm font-semibold text-gold-mid bg-navy-deep rounded-lg mt-2 text-center">
        WhatsApp Kami
      </a>
    </div>
  </div>
</nav>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
