---
import type { BlogArticle } from "@/lib/types";

export interface Props {
  article: BlogArticle;
}

const { article } = Astro.props;
---

<a href={`/blog/${article.slug}/`} class="group block">
  <div class="relative aspect-[16/10] rounded-[40px] overflow-hidden mb-8 shadow-xl transition-transform duration-500 group-hover:-translate-y-2 bg-[var(--cream-warm)]">
    {article.thumbnailUrl ? (
      <img src={article.thumbnailUrl} alt={article.title} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" />
    ) : (
      <div class="w-full h-full flex items-center justify-center">
        <svg class="w-16 h-16 text-[var(--gold-deep)]/20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
      </div>
    )}
    <div class="absolute inset-0 bg-gradient-to-t from-[var(--black-pearl)]/60 via-transparent to-transparent opacity-60"></div>
  </div>
  <div class="px-2">
    <span class="text-[var(--gold-deep)] text-[10px] font-bold uppercase tracking-[0.3em] mb-4 block">Artikel</span>
    <h2 class="text-2xl font-extrabold text-[var(--black-pearl)] mb-4 group-hover:text-[var(--gold-deep)] transition-colors leading-tight">
      {article.title}
    </h2>
    <p class="text-[var(--black-pearl)]/60 line-clamp-3 leading-relaxed mb-8">
      {article.excerpt}
    </p>
    <span class="flex items-center text-[var(--black-pearl)] font-bold text-[10px] uppercase tracking-widest group-hover:translate-x-3 transition-transform duration-300">
      Baca Selengkapnya
      <svg class="w-4 h-4 ml-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
    </span>
  </div>
</a>
