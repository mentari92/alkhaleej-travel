---
/**
 * AdminLayout Component — Tropical Ocean Design
 * Admin layout with collapsible sidebar navigation and auth check.
 * Uses the same ocean theme as the public site for consistency.
 * Admin UI is in Bahasa Indonesia only.
 * Validates: Requirements 4.2, 5.3
 */
import "@/styles/globals.css";

export interface Props {
  title: string;
}

const { title } = Astro.props;
const currentPath = Astro.url.pathname;

const navItems = [
  { href: "/admin", label: "Dashboard", icon: "home" },
  { href: "/admin/destinations", label: "Destinasi", icon: "map-pin" },
  { href: "/admin/blog", label: "Blog", icon: "file-text" },
  { href: "/admin/blog/generate", label: "AI Generate", icon: "sparkles" },
];
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{title} - Admin Alkhaleej Travel</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Figtree:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body class="min-h-screen bg-background text-foreground font-sans antialiased">
    <div class="flex min-h-screen">
      <!-- Sidebar (collapsible) -->
      <aside
        id="admin-sidebar"
        class="hidden md:flex md:flex-col md:fixed md:inset-y-0 transition-all duration-300 bg-ocean-deep"
        data-expanded="true"
        style="width: 16rem;"
      >
        <div class="flex flex-col flex-1 overflow-y-auto">
          <!-- Logo / Brand -->
          <div class="flex items-center justify-between h-16 px-4 border-b border-white/10">
            <a href="/admin" class="flex items-center gap-2 font-display font-bold text-white sidebar-brand">
              <span class="grid place-items-center w-8 h-8 rounded-lg bg-lagoon/80 flex-shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="10"/><polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"/>
                </svg>
              </span>
              <span class="sidebar-label">Alkhaleej <span class="text-lagoon">Travel</span></span>
            </a>
            <!-- Collapse toggle -->
            <button
              id="sidebar-toggle"
              class="p-1.5 rounded-lg text-white/60 hover:text-white hover:bg-white/10 transition"
              aria-label="Toggle sidebar"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect width="18" height="18" x="3" y="3" rx="2"/><path d="M9 3v18"/>
              </svg>
            </button>
          </div>

          <!-- Navigation -->
          <nav class="flex-1 px-3 py-4 space-y-1" aria-label="Navigasi admin">
            {navItems.map((item) => {
              const isActive = currentPath === item.href ||
                (item.href !== "/admin" && currentPath.startsWith(item.href) && item.href !== "/admin/blog/generate") ||
                (item.href === "/admin/blog/generate" && currentPath === "/admin/blog/generate");
              return (
                <a
                  href={item.href}
                  class:list={[
                    "flex items-center gap-3 px-3 py-2.5 text-sm font-medium rounded-xl transition-colors min-h-[44px]",
                    isActive
                      ? "bg-lagoon/20 text-white border border-lagoon/30"
                      : "text-white/70 hover:bg-white/10 hover:text-white",
                  ]}
                  aria-current={isActive ? "page" : undefined}
                  title={item.label}
                >
                  {item.icon === "home" && (
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M15 21v-8a1 1 0 0 0-1-1h-4a1 1 0 0 0-1 1v8"/><path d="M3 10a2 2 0 0 1 .709-1.528l7-5.999a2 2 0 0 1 2.582 0l7 5.999A2 2 0 0 1 21 10v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
                    </svg>
                  )}
                  {item.icon === "map-pin" && (
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/><circle cx="12" cy="10" r="3"/>
                    </svg>
                  )}
                  {item.icon === "file-text" && (
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M10 9H8"/><path d="M16 13H8"/><path d="M16 17H8"/>
                    </svg>
                  )}
                  {item.icon === "sparkles" && (
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"/>
                      <path d="M20 3v4"/><path d="M22 5h-4"/>
                    </svg>
                  )}
                  <span class="sidebar-label">{item.label}</span>
                </a>
              );
            })}
          </nav>

          <!-- Bottom: back to site -->
          <div class="px-3 py-4 border-t border-white/10">
            <a
              href="/"
              class="flex items-center gap-3 px-3 py-2.5 text-sm font-medium text-white/60 hover:text-white hover:bg-white/10 rounded-xl transition-colors"
              title="Kembali ke situs"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" x2="3" y1="12" y2="12"/>
              </svg>
              <span class="sidebar-label">Kembali ke Situs</span>
            </a>
          </div>
        </div>
      </aside>

      <!-- Main content area -->
      <div id="admin-main" class="flex flex-col flex-1 transition-all duration-300" style="margin-left: 16rem;">
        <!-- Top header bar -->
        <header class="sticky top-0 z-10 flex items-center justify-between h-16 px-4 sm:px-6 bg-card border-b border-border shadow-soft">
          <!-- Mobile menu button -->
          <button
            type="button"
            id="mobile-menu-btn"
            class="md:hidden inline-flex items-center justify-center p-2 rounded-lg text-muted-foreground hover:text-foreground hover:bg-secondary min-w-[44px] min-h-[44px]"
            aria-label="Buka menu navigasi"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/>
            </svg>
          </button>

          <h1 class="text-lg font-display font-semibold text-foreground">{title}</h1>

          <!-- Logout button -->
          <form method="POST" action="/api/auth/logout">
            <button
              type="submit"
              class="inline-flex items-center gap-2 px-3 py-2 text-sm font-medium text-muted-foreground hover:text-foreground hover:bg-secondary rounded-lg transition-colors min-h-[44px]"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" x2="9" y1="12" y2="12"/>
              </svg>
              <span class="hidden sm:inline">Keluar</span>
            </button>
          </form>
        </header>

        <!-- Mobile sidebar overlay -->
        <div id="mobile-sidebar" class="hidden fixed inset-0 z-40 md:hidden">
          <div id="mobile-overlay" class="fixed inset-0 bg-ocean-deep/75"></div>
          <div class="relative flex flex-col w-64 max-w-xs bg-ocean-deep h-full">
            <div class="flex items-center justify-between h-16 px-4 border-b border-white/10">
              <span class="text-white font-display font-bold text-lg">Alkhaleej Travel</span>
              <button
                type="button"
                id="mobile-close-btn"
                class="text-white/60 hover:text-white min-w-[44px] min-h-[44px] flex items-center justify-center"
                aria-label="Tutup menu"
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M18 6 6 18"/><path d="m6 6 12 12"/>
                </svg>
              </button>
            </div>
            <nav class="flex-1 px-3 py-4 space-y-1" aria-label="Navigasi admin mobile">
              {navItems.map((item) => {
                const isActive = currentPath === item.href ||
                  (item.href !== "/admin" && currentPath.startsWith(item.href));
                return (
                  <a
                    href={item.href}
                    class:list={[
                      "flex items-center gap-3 px-3 py-2.5 text-sm font-medium rounded-xl transition-colors min-h-[44px]",
                      isActive
                        ? "bg-lagoon/20 text-white border border-lagoon/30"
                        : "text-white/70 hover:bg-white/10 hover:text-white",
                    ]}
                  >
                    <span>{item.label}</span>
                  </a>
                );
              })}
            </nav>
          </div>
        </div>

        <!-- Page content -->
        <main class="flex-1 p-4 sm:p-6 lg:p-8">
          <slot />
        </main>
      </div>
    </div>

    <script>
      // Mobile menu
      const menuBtn = document.getElementById("mobile-menu-btn");
      const closeBtn = document.getElementById("mobile-close-btn");
      const mobileSidebar = document.getElementById("mobile-sidebar");
      const mobileOverlay = document.getElementById("mobile-overlay");

      function openMobileMenu() {
        mobileSidebar?.classList.remove("hidden");
      }
      function closeMobileMenu() {
        mobileSidebar?.classList.add("hidden");
      }

      menuBtn?.addEventListener("click", openMobileMenu);
      closeBtn?.addEventListener("click", closeMobileMenu);
      mobileOverlay?.addEventListener("click", closeMobileMenu);

      // Collapsible sidebar
      const sidebar = document.getElementById("admin-sidebar");
      const mainContent = document.getElementById("admin-main");
      const toggleBtn = document.getElementById("sidebar-toggle");

      const COLLAPSED_WIDTH = "4.5rem";
      const EXPANDED_WIDTH = "16rem";

      // Restore state from localStorage
      const savedState = localStorage.getItem("admin-sidebar-collapsed");
      if (savedState === "true") {
        collapseSidebar();
      }

      toggleBtn?.addEventListener("click", () => {
        const isExpanded = sidebar?.dataset.expanded === "true";
        if (isExpanded) {
          collapseSidebar();
          localStorage.setItem("admin-sidebar-collapsed", "true");
        } else {
          expandSidebar();
          localStorage.setItem("admin-sidebar-collapsed", "false");
        }
      });

      function collapseSidebar() {
        if (!sidebar || !mainContent) return;
        sidebar.dataset.expanded = "false";
        sidebar.style.width = COLLAPSED_WIDTH;
        mainContent.style.marginLeft = COLLAPSED_WIDTH;
        sidebar.querySelectorAll(".sidebar-label").forEach((el) => {
          (el as HTMLElement).style.display = "none";
        });
        sidebar.querySelectorAll(".sidebar-brand").forEach((el) => {
          (el as HTMLElement).style.justifyContent = "center";
        });
      }

      function expandSidebar() {
        if (!sidebar || !mainContent) return;
        sidebar.dataset.expanded = "true";
        sidebar.style.width = EXPANDED_WIDTH;
        mainContent.style.marginLeft = EXPANDED_WIDTH;
        sidebar.querySelectorAll(".sidebar-label").forEach((el) => {
          (el as HTMLElement).style.display = "";
        });
        sidebar.querySelectorAll(".sidebar-brand").forEach((el) => {
          (el as HTMLElement).style.justifyContent = "";
        });
      }
    </script>
  </body>
</html>
